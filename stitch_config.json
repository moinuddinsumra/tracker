{
    "stitch": {
        "client": {
            "version": "1.0.0",
            "name": "AetherOS Web Tracker Client",
            "environment": "local"
        },
        "project": {
            "id": "15830368362532184775",
            "title": "Login Activity Tracker",
            "design_system_ref": "assets/1a5c248d90c343568e96885cb6a3397a",
            "theme": "Cyber-Luxury Glass"
        },
        "integration": {
