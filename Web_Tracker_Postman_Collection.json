{
	"info": {
		"_postman_id": "4b68e98b-285f-45a0-a541-11d5961e0bc1",
		"name": "Laravel Web Tracker System Core APIs",
		"description": "Comprehensive suite of REST endpoints protecting administrative data logs and tracking sessions. Implements Sanctum Bearer tokens and dynamic variables mapping.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Operator Authorization (Login)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.status === 'success' && jsonData.token) {",
									"    pm.collectionVariables.set(\"accessToken\", jsonData.token);",
									"    console.log(\"Terminal security clearance established. Token cached.\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@core.sys\",\n    \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"login"
							]
						},
						"description": "Authenticate user credentials, capture active IP details, increment database log counters, and capture a secure session token."
					},
					"response": []
				},
				{
					"name": "Revoke Session (Logout)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/logout",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"logout"
							]
						},
						"description": "Destroy the authenticated Sanctum bearer token and log the termination timestamp."
					},
					"response": []
				}
			]
		},
		{
			"name": "System Monitors",
			"item": [
				{
					"name": "Get Users Registry",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users"
							]
						},
						"description": "Retrieve list of all registered users in the database directory."
					},
					"response": []
				},
				{
					"name": "Get Activity Log Stream",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/login-activities",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"login-activities"
							]
						},
						"description": "Fetch a list of all logged session tracking logs."
					},
					"response": []
				},
				{
					"name": "Get Merged Registry Analytics (SQL JOIN)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/dashboard-data",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"dashboard-data"
							]
						},
						"description": "Fetch live administrative logs showing user details merged with cumulative activity logs through an optimized left database JOIN."
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:8000",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "PasteSecureTokenHere",
			"type": "string"
		}
	]
}
